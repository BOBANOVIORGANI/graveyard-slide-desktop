{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Graveyard Slide",
  "version": "0.1.2",
  "identifier": "com.marin.graveyardslide",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Graveyard Slide",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "minimizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Marin Golub",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BOBANOVIORGANI/graveyard-slide-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGQjkwMjM0MkU4OEQxQ0YKUldUUDBZZ3VOQUs1ZitRRldaQm5NYlVHdFAybFEra3RvYnFhMjZnTjJaNm9nWU14L2pvd0h3VnEK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
