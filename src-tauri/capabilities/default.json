{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the main window",
  "windows": ["main"],
  "permissions": [
    "updater:default",
    "process:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:event:allow-listen",
    "core:event:default",
    "core:app:allow-version"
  ]
}